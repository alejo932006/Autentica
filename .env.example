# Copiar a .env en la raíz del proyecto (local y servidor Windows)
# Base de datos PostgreSQL
DB_USER=postgres
DB_HOST=localhost
DB_NAME=Autentika
DB_PASSWORD=TU_PASSWORD
DB_PORT=5432

# Autenticación JWT
JWT_SECRET=cambiar_por_un_secreto_largo

# Servidor
PORT=8080
BASE_URL=https://api.auntentika.com

# Usuario admin inicial (node init-autentica.js)
ADMIN_USER=admin
ADMIN_PASSWORD=cambiar_password
